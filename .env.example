# Core
APP_ENV=development
DEBUG=True

# Django
DJANGO_SECRET_KEY=change-me-in-development
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,django
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
POSTGRES_DB=recruitment_db
POSTGRES_USER=recruit_user
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://recruit_user:changeme@postgres:5432/recruitment_db

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# AI provider
# Development can use Ollama Cloud. Local Ollama remains a future/offline option.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_API_KEY=
LLM_MODEL=qwen2.5-coder:7b
LLM_FALLBACK_MODELS=mistral,phi3
OLLAMA_NUM_PREDICT=4096
OLLAMA_TIMEOUT_SECONDS=120
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# Supabase managed project values for later sprints.
# Keep service role keys server-side only.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=resumes
SUPABASE_CLI_VERSION=2.26.9
