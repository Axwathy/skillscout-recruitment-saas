# ============================================================
# Lumina Nexus - Frontend Environment Variables
# Copy to .env.local for local development.
# Never commit .env.local to version control.
# ============================================================

# ----- API -----
# URL of the Django backend API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----- App -----
# Application base URL (used for redirects, SEO, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Supabase (used from Sprint 3 onwards) -----
# Public anon key is browser-safe, but keep real project values out of examples.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
